<?xml version="1.0" encoding="UTF-8"?>
<manifest>

  <!-- AAOSP Remote -->
  <remote name="aaosp"
          fetch="https://github.com/rufolangus"
          revision="aaosp" />

  <!--
    Override upstream frameworks/base with our fork.
    The "remove-project" drops the AOSP original so ours takes its place.
  -->
  <remove-project name="platform/frameworks/base" />
  <project path="frameworks/base"
           name="platform_frameworks_base"
           remote="aaosp"
           revision="aaosp" />

  <!-- New projects (not in upstream AOSP) -->

  <!-- Agentic Launcher -->
  <project path="packages/apps/AgenticLauncher"
           name="platform_packages_apps_AgenticLauncher"
           remote="aaosp"
           revision="main" />

  <!-- llama.cpp native runtime -->
  <project path="external/llama.cpp"
           name="platform_external_llamacpp"
           remote="aaosp"
           revision="main" />

</manifest>
